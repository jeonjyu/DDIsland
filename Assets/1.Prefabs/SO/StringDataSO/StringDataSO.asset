    - Basic Mailbox
  - key: InteriorNameMediumFlowerPot_String
    values:
    - "\uC911\uAC04 \uD06C\uAE30 \uD654\uBD84"
    - Smiling Plant Pot
  - key: InteriorNameLargeFlowerPot_String
    values:
    - "\uD070 \uC0AC\uC774\uC988 \uD654\uBD84"
    - Sleeping Plant Pot
  - key: InteriorNameBasicFence_String
    values:
    - "\uAE30\uBCF8 \uC6B8\uD0C0\uB9AC"
    - Medium Plant Pot
  - key: InteriorNameBasicLpPlayer_String
    values:
    - "\uAE30\uBCF8 LP \uD50C\uB808\uC774\uC5B4"
    - Large Plant Pot
