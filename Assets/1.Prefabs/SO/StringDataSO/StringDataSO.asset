  - key: RecordMessageUnlock
    values:
    - "\uC74C\uBC18 \uC870\uAC01 3\uAC1C\uB97C \uC18C\uBAA8\uD558\uC5EC \uC0C8\uB85C\uC6B4
      \uC74C\uBC18\uC744 \uD574\uAE08\uD560\uAE4C\uC694?"
